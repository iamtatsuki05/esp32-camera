ESP32_CAMERA_SERVER_URL=http://192.168.0.10:8000/api/v1/frames
ESP32_CAMERA_ID=esp32-cam-01
ESP32_WIFI_SSID=replace-with-your-wifi-ssid
ESP32_WIFI_PASSWORD=replace-with-your-wifi-password
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
SERVER_OUTPUT_DIR=data/outputs
ANALYZER=mock-yolo
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25
SAVE_JPEG_QUALITY=85
VIDEO_FPS=2.0
UPLOADER_MODE=dry-run
